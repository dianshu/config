#!/usr/bin/env zsh
# Toggle MacBook built-in screen on/off.
#   off: displayplacer disables the built-in panel (a real power-off).
#        While disabling it, displayplacer prints "Unable to find screen ..."
#        and returns non-zero, but the disable still takes effect — that noise
#        is suppressed and the result is confirmed by re-listing displays.
#   on:  displayplacer CANNOT re-enable a disabled built-in screen: once off it
#        leaves the online display list and becomes unaddressable (a documented
#        displayplacer limitation). Instead we start then quit BetterDisplay;
#        quitting it triggers a display-topology reset that brings the built-in
#        panel back — no reboot needed. (If BetterDisplay was already running,
#        this quits it; recovery requires the quit, so that is expected.)
# Requires: displayplacer, BetterDisplay
action="${1:-off}"

if ! command -v displayplacer >/dev/null 2>&1; then
  echo "需要 displayplacer：brew install displayplacer"
  exit 1
fi

# 内置屏当前是否在线
builtin_online() { displayplacer list 2>/dev/null | grep -qE 'Type:.*built.in'; }

case "$action" in
  off)
    builtin_id=$(displayplacer list 2>/dev/null | awk '
      /^Persistent screen id:/ { id = $NF }
      /Type:.*built.in/ { print id; exit }
    ')
    if [[ -z "$builtin_id" ]]; then
      echo "内置屏未找到（可能已关闭）；若要开启请运行: screen-builtin on"
      exit 1
    fi
    # disable 内置屏时 displayplacer 会刷 "Unable to find screen" 噪音且退出码非 0，
    # 但实际已生效，故抑制输出，再以重新列举确认结果（真失败时如实报错）。
    displayplacer "id:$builtin_id enabled:false" >/dev/null 2>&1
    sleep 1
    if builtin_online; then
      echo "内置屏关闭失败（仍在线）；可能系统拒绝禁用（如它是当前唯一显示器）"
      exit 1
    fi
    echo "内置屏已关闭"
    ;;
  on)
    if builtin_online; then
      echo "内置屏已是开启状态"
      exit 0
    fi
    # displayplacer 无法重新启用已禁用的内置屏（已离线、不可寻址）。
    # 改用 BetterDisplay 的启停触发显示重置来恢复。open -a 经 LaunchServices
    # 解析（覆盖任意安装位置），其退出码亦可捕获启动失败。
    if ! open -g -a BetterDisplay 2>/dev/null; then
      echo "无法启动 BetterDisplay：displayplacer 无法重新启用已禁用的内置屏，"
      echo "需靠 BetterDisplay 启停触发显示重置来恢复。请确认已安装 BetterDisplay。"
      exit 1
    fi
    sleep 6                                       # 等 BetterDisplay 接管显示子系统
    osascript -e 'quit app "BetterDisplay"' >/dev/null 2>&1
    # 退出触发显示重置，轮询等待内置屏回到在线列表
    for _ in {1..12}; do
      if builtin_online; then
        echo "内置屏已开启"
        exit 0
      fi
      sleep 1
    done
    echo "内置屏未在预期时间内恢复；可再次运行 screen-builtin on，或重启"
    exit 1
    ;;
  *)
    echo "用法: screen-builtin [off|on]"
    exit 1
    ;;
esac
