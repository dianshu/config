#!/usr/bin/env bash
# wda — start WDA + keep iPhone awake, all foreground.
# Ctrl+C stops everything (xcuitest runner connection, port forward, keepalive loop).
# Run from one terminal at a time; a second invocation will error on port 8100.
set -uo pipefail

RUNNER_BUNDLE="com.facebook.WebDriverAgentRunner.xctrunner"
PORT=8100
WDA="http://localhost:$PORT"
INTERVAL=120
TAP_X=200
TAP_Y=1

XCUITEST_PID=""
FORWARD_PID=""

log() { echo "[$(date +%H:%M:%S)] $*"; }

cleanup() {
  trap - INT TERM HUP EXIT
  log "stopping"
  [[ -n "$FORWARD_PID"  ]] && kill "$FORWARD_PID"  2>/dev/null || true
  [[ -n "$XCUITEST_PID" ]] && kill "$XCUITEST_PID" 2>/dev/null || true
  wait 2>/dev/null || true
  exit 0
}
trap cleanup INT TERM HUP EXIT

# 1. Preconditions
UDID=$(idevice_id -l | head -n1 || true)
[[ -z "$UDID" ]] && { log "ERROR: no iOS device. Plug in & unlock."; exit 1; }
log "device $UDID"

curl -fsS --max-time 2 http://127.0.0.1:49151/ >/dev/null 2>&1 \
  || { log "ERROR: tunneld not on :49151"; exit 1; }

if lsof -iTCP:$PORT -sTCP:LISTEN >/dev/null 2>&1; then
  occupant_cmd=$(lsof -iTCP:$PORT -sTCP:LISTEN -F c 2>/dev/null | awk '/^c/{print substr($0,2); exit}')
  occupant_pid=$(lsof -iTCP:$PORT -sTCP:LISTEN -F p 2>/dev/null | awk '/^p/{print substr($0,2); exit}')
  if [[ "$occupant_cmd" == python3* ]] || [[ "$occupant_cmd" == pymobiledevice* ]]; then
    log "stale pymobiledevice3 holding :$PORT (pid=$occupant_pid) — killing"
    kill "$occupant_pid" 2>/dev/null || true
    sleep 1
    if lsof -iTCP:$PORT -sTCP:LISTEN >/dev/null 2>&1; then
      log "ERROR: :$PORT still in use after kill"; exit 1
    fi
  else
    log "ERROR: :$PORT held by '$occupant_cmd' (pid=$occupant_pid) — not ours, refusing to kill"
    exit 1
  fi
fi

# Sweep stale pymobiledevice3 children from a previous crashed run.
pkill -f "pymobiledevice3 developer dvt xcuitest" 2>/dev/null || true
pkill -f "pymobiledevice3 usbmux forward $PORT"   2>/dev/null || true
sleep 1

# 2. xcuitest runner
log "starting xcuitest runner..."
pymobiledevice3 developer dvt xcuitest --tunnel "$UDID" "$RUNNER_BUNDLE" \
  >/tmp/wda-xcuitest.log 2>&1 &
XCUITEST_PID=$!

# 3. usbmux forward
sleep 3
log "starting usbmux forward $PORT..."
pymobiledevice3 usbmux forward "$PORT" "$PORT" --udid "$UDID" \
  >/tmp/wda-forward.log 2>&1 &
FORWARD_PID=$!

# 4. wait until WDA ready
for i in $(seq 1 30); do
  if curl -fsS --max-time 2 "$WDA/status" >/dev/null 2>&1; then
    log "WDA ready (${i}s)"
    break
  fi
  sleep 1
  if (( i == 30 )); then
    log "ERROR: WDA didn't become ready in 30s. Check /tmp/wda-xcuitest.log"
    exit 1
  fi
done

# 5. keepalive loop (foreground)
log "keepalive every ${INTERVAL}s — Ctrl+C to stop"
SID=""
while true; do
  if ! kill -0 "$XCUITEST_PID" 2>/dev/null; then
    log "xcuitest runner died — exiting"; exit 1
  fi
  if ! kill -0 "$FORWARD_PID" 2>/dev/null; then
    log "usbmux forward died — exiting"; exit 1
  fi
  if ! curl -fsS --max-time 3 "$WDA/status" >/dev/null 2>&1; then
    log "WDA dropped — exiting"; exit 1
  fi

  if [[ -z "$SID" ]]; then
    BID=$(curl -fsS --max-time 3 "$WDA/wda/activeAppInfo" \
      | python3 -c 'import sys,json;print(json.load(sys.stdin)["value"]["bundleId"])' 2>/dev/null || true)
    if [[ -z "$BID" ]]; then
      log "no active app (locked?); retry in ${INTERVAL}s"
      sleep "$INTERVAL"; continue
    fi
    if [[ "$BID" == "com.apple.springboard" ]]; then
      log "active app is SpringBoard; using com.apple.Preferences instead"
      BID="com.apple.Preferences"
    fi
    SID=$(curl -fsS --max-time 5 -X POST "$WDA/session" \
      -H 'Content-Type: application/json' \
      -d "{\"capabilities\":{\"alwaysMatch\":{\"bundleId\":\"$BID\"}}}" \
      | python3 -c 'import sys,json;print(json.load(sys.stdin)["value"]["sessionId"])' 2>/dev/null || true)
    if [[ -z "$SID" ]]; then
      log "session create failed against $BID; retry in ${INTERVAL}s"
      sleep "$INTERVAL"; continue
    fi
    log "session=$SID (bundle=$BID)"
  fi

  code=$(curl -fsS -o /dev/null -w '%{http_code}' --max-time 5 \
    -X POST "$WDA/session/$SID/wda/tap" \
    -H 'Content-Type: application/json' \
    -d "{\"x\":$TAP_X,\"y\":$TAP_Y}" 2>/dev/null || echo 000)
  if [[ "$code" == "200" ]]; then
    log "tap ok"
  else
    log "tap http=$code — recreating session"
    SID=""
  fi

  sleep "$INTERVAL"
done
