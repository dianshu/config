# Claude Code 环境变量
# 复制此文件到 ~/.claude/user.env 并填入实际值
# cp user.env.template ~/.claude/user.env

PLACEHOLDER_VALUE="placeholder"

export NOT_EXIST_API_KEY=$PLACEHOLDER_VALUE
export NOT_EXIST_API_KEY2=$PLACEHOLDER_VALUE

# Add required env names here as new secrets are introduced.
required_envs=(
	NOT_EXIST_API_KEY
	NOT_EXIST_API_KEY2
)

for env_name in "${required_envs[@]}"; do
	env_value="${(P)env_name}"

	if [[ -z "$env_value" ]]; then
		echo "Warning: $env_name is not set." >&2
	fi

	if [[ "$env_value" == "$PLACEHOLDER_VALUE" ]]; then
		echo "Warning: $env_name still uses PLACEHOLDER_VALUE." >&2
	fi
done
