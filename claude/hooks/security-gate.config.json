{
  "model": "claude-sonnet-4-6",
  "max_tokens": 150,
  "timeout_seconds": 10,
  "cache_ttl_seconds": 300,
  "log_file": "~/.claude/hooks/security-gate.log",

  "bash_whitelist_prefixes": [
    "ls", "pwd", "echo ", "date", "whoami", "cat ", "head ", "tail ",
    "wc ", "sort ", "uniq ", "diff ", "file ", "which ", "where ",
    "git status", "git log", "git diff", "git branch", "git show",
    "git rev-parse", "git remote", "git tag", "git stash list",
    "git add", "git commit", "git checkout", "git switch", "git merge",
    "git fetch", "git pull", "git rebase", "git cherry-pick",
    "cd ", "env ", "printenv", "type ",
    "python3 -c", "python3 -m py_compile", "python3 -m pytest",
    "npm test", "npm run", "npx ", "node ",
    "pytest", "ruff ", "mypy ", "black ", "isort ",
    "pip list", "pip show", "pip3 list", "pip3 show",
    "cargo ", "go ", "make ", "cmake ",
    "docker ps", "docker images", "docker logs",
    "grep ", "find ", "rg ", "fd ",
    "chmod +x", "mkdir ", "touch ", "cp ", "mv ",
    "curl -s", "wget -q",
    "az ", "gh ", "jq ", "yq ",
    "codex "
  ],

  "bash_deny_patterns": [
    "rm\\s+-[^\\s]*r[^\\s]*f|rm\\s+-[^\\s]*f[^\\s]*r",
    "rm\\s+-rf\\s+/\\s*$",
    ":(\\s*)\\{(\\s*):(\\s*)\\|(\\s*):(\\s*)&(\\s*)\\}",
    "mkfs\\.",
    "dd\\s+if=.*of=/dev/",
    ">\\s*/dev/sd",
    "curl\\s+.*\\|\\s*(ba)?sh",
    "wget\\s+.*\\|\\s*(ba)?sh",
    "chmod\\s+777",
    "\\bsudo\\b",
    "\\bsu\\s+-",
    "git\\s+push\\s+--force",
    "git\\s+reset\\s+--hard",
    "git\\s+clean\\s+-[^\\s]*f",
    "\\beval\\b",
    ">/dev/null\\s*2>&1\\s*&\\s*disown",
    "nohup\\s+.*&"
  ],

  "write_deny_paths": [
    "**/.env", "**/.env.*",
    "**/credentials*", "**/*secret*", "**/*token*",
    "~/.ssh/*", "~/.aws/*", "~/.gnupg/*",
    "/etc/*", "/usr/*", "/sys/*", "/boot/*", "/proc/*"
  ]
}
