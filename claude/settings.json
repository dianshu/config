{
  "env": {
    "ANTHROPIC_BASE_URL": "http://localhost:29427",
    "ANTHROPIC_AUTH_TOKEN": "your-anthropic-auth-token",
    "CLAUDE_CODE_SKIP_AUTH_LOGIN": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash",
      "WebFetch",
      "WebSearch",
      "mcp__plugin_microsoft-docs_microsoft-learn",
      "mcp__plugin_context7_context7"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)"
    ],
    "defaultMode": "plan",
    "additionalDirectories": [
      "~/repos/",
      "~/.claude/",
      "~/.agents/",
      "/tmp/"
    ]
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh",
    "padding": 0
  },
  "effortLevel": "high"
}
