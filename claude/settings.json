{
  "env": {
    "ANTHROPIC_BASE_URL": "http://localhost:29427",
    "ANTHROPIC_AUTH_TOKEN": "your-anthropic-auth-token",
    "CLAUDE_CODE_SKIP_AUTH_LOGIN": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "ENABLE_STOP_REVIEW": "0"
  },
  "permissions": {
    "allow": [
      "Bash",
      "WebFetch",
      "WebSearch",
      "mcp__plugin_microsoft-docs_microsoft-learn",
      "mcp__context7",
      "mcp__searxng",
      "mcp__chrome",
      "mcp__mail",
      "mcp__s360",
      "mcp__xcodebuildmcp",
      "Write(~/repos/**)",
      "Write(/tmp/**)",
      "Write(~/.claude/**)",
      "Write(~/.codex/**)",
      "Write(~/.gemini/**)",
      "Skill(codex-review)",
      "Skill(gemini-review)",
      "Skill(review-with-agent)",
      "Skill(review-loop)",
      "Skill(prd-review-loop)",
      "Skill(simplify)",
      "Skill(e2e-verify)",
      "Skill(diagnose)",
      "Skill(grill)",
      "Skill(improve-codebase-architecture)",
      "Skill(issues)",
      "Skill(load-feature)",
      "Skill(prd)",
      "Skill(run-all-issues)",
      "Skill(run-next-issue)",
      "Skill(tdd)",
      "Skill(triage)",
      "Skill(zoom-out)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "~/",
      "/tmp/"
    ]
  },
  "model": "claude-opus-4-7[1m]",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-deps-check.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/load-project-rules.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/inject-one-user-rule.sh azure"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/inject-one-user-rule.sh bash-timeout"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/inject-one-user-rule.sh checkpoint-after-steps"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/inject-one-user-rule.sh code-discipline"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/inject-one-user-rule.sh code-review"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/inject-one-user-rule.sh commit-behavior"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/inject-one-user-rule.sh context7"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/inject-one-user-rule.sh debug-discipline"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/inject-one-user-rule.sh first-principles"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/inject-one-user-rule.sh language"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/inject-one-user-rule.sh large-file-writing"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/inject-one-user-rule.sh model-judgment-only"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/inject-one-user-rule.sh no-stalling"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/inject-one-user-rule.sh prd-review"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/inject-one-user-rule.sh prompt-supersedes-rules"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/inject-one-user-rule.sh question-format"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/inject-one-user-rule.sh skills-summary"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/inject-one-user-rule.sh surface-conflicts"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/inject-one-user-rule.sh testing"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/inject-one-user-rule.sh update-readme"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/inject-one-user-rule.sh verify-against-diff"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/inject-one-user-rule.sh web-fetching"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-learnings.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/remind-user-rules.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__chrome__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/chrome-ensure.sh",
            "statusMessage": "Ensuring Chrome is running..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/swift-build-check.sh",
            "statusMessage": "Running xcodebuild warning check..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/ts-typecheck.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/py-syntaxcheck.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/py-ruff.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/swift-lint.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/open-spec-plan.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh",
    "padding": 0
  },
  "outputStyle": "explanatory",
  "effortLevel": "xhigh",
  "enableWorkflows": true,
  "ultracode": true
}
