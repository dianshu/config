{
  "env": {
    "ANTHROPIC_BASE_URL": "http://localhost:29427",
    "ANTHROPIC_AUTH_TOKEN": "your-anthropic-auth-token",
    "CLAUDE_CODE_SKIP_AUTH_LOGIN": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS" = "1"
  },
  "permissions": {
    "allow": [
      "Bash",
      "WebFetch",
      "WebSearch",
      "mcp__microsoft-docs",
      "mcp__context7"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)"
    ],
    "defaultMode": "plan"
  },
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh",
    "padding": 0
  },
  "effortLevel": "high"
}
